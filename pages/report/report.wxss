.page {
  width: 100%;
  box-sizing: border-box;
}

.page-inner {
  width: 100%;
  max-width: 680rpx;
  margin: 0 auto;
  /* 高度由 report.js 写入 windowHeight，避免 100vh 与导航栏/安全区组合问题 */
  padding: var(--space-xl) calc(var(--space-xl) + var(--safe-right))
    calc(var(--space-2xl) + var(--space-2xl) + var(--space-lg) + var(--safe-bottom))
    calc(var(--space-xl) + var(--safe-left));
  box-sizing: border-box;
}

/* 入场前略收起，避免闪屏过久 */
.page:not(.page--entered) .delight-rise {
  opacity: 0;
  transform: translateY(24rpx);
}

.score-block {
  position: relative;
  text-align: center;
  margin-bottom: var(--space-2xl);
  padding: var(--space-2xl) var(--space-lg) var(--space-2xl);
  background: var(--fill-glass-strong);
  border: 4rpx solid var(--ink);
  border-radius: 24rpx 20rpx 28rpx 22rpx;
  box-shadow: var(--shadow-3);
  overflow: visible;
}

.score-block::after {
  content: "";
  position: absolute;
  left: -20%;
  top: -30%;
  width: 60%;
  height: 160%;
  transform: rotate(18deg) translateX(-120%);
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.28),
    rgba(255, 255, 255, 0.08),
    transparent
  );
  opacity: 0;
  pointer-events: none;
}

.page--entered .score-block::after {
  animation: ink-sweep 0.85s var(--ease-out) 0.12s both;
}

@keyframes ink-sweep {
  0% {
    opacity: 0;
    transform: rotate(18deg) translateX(-120%);
  }
  18% {
    opacity: 1;
  }
  100% {
    opacity: 0;
    transform: rotate(18deg) translateX(260%);
  }
}

.stamp {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-md);
  font-size: 22rpx;
  font-weight: 800;
  color: var(--ink);
  border: 3rpx solid var(--ink);
  padding: var(--space-xs) var(--space-sm);
  letter-spacing: 3rpx;
  transform: rotate(-14deg);
  opacity: 0;
  pointer-events: none;
}

.page--entered .stamp {
  animation: stamp-in 0.45s var(--ease-out) 0.42s forwards;
}

@keyframes stamp-in {
  0% {
    opacity: 0;
    transform: rotate(-26deg) scale(1.35);
  }
  100% {
    opacity: 0.88;
    transform: rotate(-14deg) scale(1);
  }
}

.score-num {
  font-size: 120rpx;
  font-weight: 800;
  color: var(--ink);
  line-height: 1;
  display: block;
  font-family: "Kaiti SC", "STKaiti", "Songti SC", "PingFang SC", serif;
}

.page--entered .score-num {
  animation: score-pop 0.62s var(--ease-out) 0.08s both;
}

@keyframes score-pop {
  0% {
    transform: scale(0.86);
    opacity: 0;
  }
  58% {
    transform: scale(1.04);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.grade {
  font-size: 36rpx;
  color: var(--ink-soft);
  display: block;
  margin-top: var(--space-md);
  font-weight: 700;
}

.grade-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: var(--space-xs);
}

.delight-line {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: var(--space-md);
  line-height: 1.55;
  padding: 0 var(--space-sm);
  font-weight: 500;
}

.delight-hidden {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: var(--space-md);
  line-height: 1.55;
  padding: var(--space-md) var(--space-md) 0;
  border-top: 2rpx dashed var(--border-subtle);
  font-weight: 600;
  letter-spacing: 0.5rpx;
  opacity: 0;
}

.page--entered .delight-hidden {
  animation: hidden-reveal 0.5s var(--ease-out) 0.52s forwards;
}

@keyframes hidden-reveal {
  0% {
    opacity: 0;
    transform: translateY(12rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.report-block {
  margin-bottom: var(--space-lg);
}

.section-title {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: var(--space-md);
  font-weight: 600;
  padding-bottom: var(--space-xs);
  border-bottom: 3rpx dashed var(--border-soft);
  display: inline-block;
  max-width: 100%;
}

.page--entered .delight-rise {
  animation: delight-rise 0.52s var(--ease-out) both;
}

.page--entered .delight-rise--1 {
  animation-delay: 0.1s;
}

.page--entered .delight-rise--2 {
  animation-delay: 0.18s;
}

.page--entered .delight-rise--3 {
  animation-delay: 0.26s;
}

.page--entered .delight-rise--4 {
  animation-delay: 0.34s;
}

@keyframes delight-rise {
  0% {
    opacity: 0;
    transform: translateY(24rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.actions {
  margin-top: var(--space-2xl);
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.btn-press {
  opacity: 0.9;
  transform: translate(4rpx, 5rpx);
  box-shadow: var(--shadow-1) !important;
}

.btn-press-ghost {
  opacity: 0.55;
}

.actions-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
  margin-top: var(--space-xs);
  text-align: center;
  padding: 0 var(--space-sm);
}

.actions-hint--sub {
  margin-top: 0;
  opacity: 0.92;
}

.actions-secondary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm) var(--space-md);
  padding: var(--space-lg) var(--space-xs) var(--space-xs);
}

.btn-inline {
  margin: 0;
  padding: var(--space-sm) var(--space-md);
  width: auto !important;
  height: auto;
  min-height: 88rpx;
  line-height: 1.4;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: transparent;
  color: var(--ink-soft);
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  border-bottom: 3rpx dashed var(--border-soft);
  border-radius: 0;
  transition: opacity 0.12s var(--ease-out);
}

.btn-inline--press {
  opacity: 0.5;
}

.btn-inline::after {
  border: none;
}

.link-tap {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-soft);
  border-bottom: 3rpx dashed var(--border-soft);
  padding: var(--space-sm) var(--space-md) var(--space-xs);
  min-height: 88rpx;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  transition: opacity 0.12s var(--ease-out);
  text-decoration: none;
}

.link-tap--pressed {
  opacity: 0.52;
}

.btn {
  width: 100% !important;
  min-height: 96rpx;
  height: auto;
  line-height: 1.3;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) var(--space-lg);
  box-sizing: border-box;
  transition:
    transform 0.12s var(--ease-out),
    opacity 0.12s var(--ease-out),
    box-shadow 0.12s var(--ease-out);
}

.foot-risk {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: var(--space-xl);
  line-height: 1.55;
  padding: var(--space-sm) var(--space-md);
  border: 1rpx dashed var(--border-subtle);
  border-radius: 12rpx 14rpx 10rpx 16rpx;
  background: var(--fill-glass);
}

.empty {
  min-height: 100vh;
  width: 100%;
  max-width: 680rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xl);
  color: var(--text-secondary);
}

.empty-inner {
  width: 100%;
  max-width: 680rpx;
  margin: 0 auto;
  padding: var(--space-xl) calc(var(--space-xl) + var(--safe-right))
    calc(var(--space-2xl) + var(--safe-bottom))
    calc(var(--space-xl) + var(--safe-left));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xl);
}

.empty-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.55;
  padding: 0 var(--space-md);
  max-width: 560rpx;
}

.empty-btn {
  min-width: 280rpx;
  min-height: 96rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) var(--space-xl);
  box-sizing: border-box;
  transition:
    transform 0.12s var(--ease-out),
    opacity 0.12s var(--ease-out),
    box-shadow 0.12s var(--ease-out);
}

.empty-btn--pressed {
  opacity: 0.9;
  transform: translate(3rpx, 4rpx);
}

.share-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
  width: 375px;
  height: 640px;
}

@media (prefers-reduced-motion: reduce) {
  .page:not(.page--entered) .delight-rise {
    opacity: 1;
    transform: none;
  }

  .page--entered .delight-rise,
  .page--entered .score-num,
  .page--entered .stamp {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }

  .page--entered .score-block::after {
    animation: none !important;
    opacity: 0 !important;
  }

  .page--entered .stamp {
    opacity: 0.88 !important;
    transform: rotate(-14deg) !important;
  }

  .page--entered .delight-hidden {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }

  .btn,
  .empty-btn {
    transition: none !important;
  }

  .btn-press,
  .btn-press-ghost,
  .empty-btn--pressed {
    transform: none !important;
  }
}
