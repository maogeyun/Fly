<view class="wrap">
  <view class="nav-row">
    <view
      class="nav-back"
      hover-class="nav-back--pressed"
      hover-start-time="16"
      hover-stay-time="100"
      bindtap="onCancel"
    >取消</view>
  </view>

  <block wx:if="{{phase === 'countdown'}}">
    <view class="center">
      <text class="safety">建议佩戴手机壳，在草地或软垫上方抛掷；切勿朝向人或硬地。</text>
      <text class="count">{{countdown}}</text>
      <text class="sub">秒后自动开始收集</text>
      <text class="countdown-hint">改变主意可点左上角「取消」。</text>
    </view>
  </block>

  <block wx:elif="{{phase === 'flying'}}">
    <view class="flying-screen">
      <view class="sky">
        <view class="plane-stack plane-stack--{{flightAnim}}">
          <view class="plane-bob">
            <view class="plane-tilt" style="transform: rotate({{planeRot}}deg);">
              <view class="plane-ico"><view class="plane-ico__fold"></view></view>
            </view>
          </view>
        </view>
        <text class="flying-text">{{phaseHint}}</text>
        <text class="phase-tip">侧视曲线只是示意「起—抬—落」，好玩、好懂，不是真实弹道。</text>

        <view class="trail-panel">
          <canvas type="2d" id="liveTrajCanvas" class="live-traj-canvas"></canvas>
          <text class="trail-cap">实时侧视轨迹（采样绘制）</text>
        </view>
      </view>
      <view class="stop-wrap">
        <button
          class="btn-stop"
          hover-class="btn-stop--pressed"
          hover-start-time="16"
          hover-stay-time="100"
          bindtap="onManualStop"
        >
          <view class="btn-stop-inner">
            <text class="btn-stop-main">结束收集</text>
            <text class="btn-stop-sub">停止记录 · 去看报告</text>
          </view>
        </button>
        <text class="btn-stop-hint">落地站稳后再点，减少半空误触。</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="center gen">
      <view class="gen-plane"><view class="gen-plane__fold"></view></view>
      <text class="sub gen-title">正在生成报告…</text>
      <view class="gen-dots">
        <view class="gen-dot"></view>
        <view class="gen-dot gen-dot--b"></view>
        <view class="gen-dot gen-dot--c"></view>
      </view>
    </view>
  </block>
</view>
