.page {
  min-height: 100vh;
  max-width: 680rpx;
  margin: 0 auto;
  padding: var(--space-xl) calc(var(--space-xl) + var(--safe-right))
    calc(var(--space-md) + var(--safe-bottom))
    calc(var(--space-xl) + var(--safe-left));
  box-sizing: border-box;
}

.h2 {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: "Kaiti SC", "STKaiti", "PingFang SC", serif;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.hint {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: var(--space-lg);
  line-height: 1.45;
}

.local-card {
  background: var(--fill-glass-strong);
  border-radius: 22rpx 18rpx 24rpx 20rpx;
  padding: var(--space-lg);
  border: 3rpx solid var(--ink);
  margin-bottom: calc(var(--space-xl) + var(--space-sm));
  box-shadow: var(--shadow-2);
}

.row {
  display: flex;
  align-items: center;
  padding: var(--space-lg) 0;
  border-bottom: 2rpx dashed var(--border-subtle);
}

.row:last-child {
  border-bottom: none;
}

.rank {
  width: 48rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ink);
  font-family: "Kaiti SC", "STKaiti", "PingFang SC", serif;
}

.mid {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.time {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.sub {
  font-size: 22rpx;
  color: var(--text-muted);
}

.pts {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ink);
  font-family: "Kaiti SC", "STKaiti", "PingFang SC", serif;
}

.empty-local {
  font-size: 26rpx;
  color: var(--text-muted);
  padding: 24rpx 0;
  text-align: center;
}

.v11 {
  background: var(--bg-surface);
  border-radius: 20rpx 22rpx 18rpx 24rpx;
  padding: var(--space-lg);
  border: 3rpx dashed var(--border-soft);
}

.v11-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.v11-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.65;
  display: block;
  margin-top: 8rpx;
}
