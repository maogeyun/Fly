.dash {
  margin-top: var(--space-xl);
  padding: var(--space-lg) var(--space-lg);
  background: var(--fill-glass-strong);
  border-radius: 22rpx 20rpx 24rpx 18rpx;
  border: 3rpx solid var(--ink);
  box-shadow: var(--shadow-2);
}

.dash-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  font-family: "Kaiti SC", "STKaiti", "PingFang SC", serif;
  display: block;
  margin-bottom: var(--space-lg);
  letter-spacing: 0.5rpx;
}

.line-canvas {
  width: 100%;
  height: 200rpx;
  display: block;
  border-radius: 12rpx 14rpx 10rpx 16rpx;
  background: var(--bg-chart);
  border: 2rpx dashed var(--border-subtle);
}

.cap-line {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
  display: block;
  margin: var(--space-xs) 0 0;
  line-height: 1.35;
}

.cap-hint {
  font-size: 20rpx;
  color: var(--text-muted);
  display: block;
  margin: 6rpx 0 var(--space-lg);
  line-height: 1.45;
}

.dash-summary {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin: 0 0 var(--space-lg);
  padding: var(--space-sm) var(--space-md);
  background: var(--fill-glass);
  border-radius: 12rpx 14rpx 10rpx 16rpx;
  border: 2rpx dashed var(--border-subtle);
}

.cards {
  display: flex;
  flex-wrap: wrap;
  margin: var(--space-md) calc(-1 * var(--space-xs)) 0;
}

.card {
  box-sizing: border-box;
  width: calc(50% - 16rpx);
  margin: var(--space-xs);
  background: var(--bg-surface-raised);
  border-radius: 16rpx 14rpx 18rpx 12rpx;
  padding: 22rpx var(--space-lg);
  border: 2rpx solid var(--border-subtle);
}

.k {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
}

.v {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
  margin-top: var(--space-xs);
  display: block;
  font-family: "Kaiti SC", "STKaiti", "PingFang SC", serif;
}
