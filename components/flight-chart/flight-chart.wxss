.fc-root {
  width: 100%;
  border-radius: 20rpx 22rpx 18rpx 24rpx;
  overflow: hidden;
  background: var(--fill-glass-strong);
  border: 3rpx solid var(--ink);
  box-shadow: var(--shadow-2);
}

.fc-canvas {
  width: 100%;
  height: 300rpx;
  display: block;
}

.fc-summary {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding: var(--space-sm) var(--space-md) var(--space-md);
  background: var(--fill-glass);
  border-top: 2rpx dashed var(--border-subtle);
}
